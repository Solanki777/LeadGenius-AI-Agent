        "jsCode": "const seen = new Set();\nconst uniqueRows = [];\n\nfor (const item of items) {\n  const email = item.json[\"Email ID\"];\n  \n  if (!seen.has(email)) {\n    seen.add(email);\n    uniqueRows.push(item);\n  }\n}\n\nreturn uniqueRows;"

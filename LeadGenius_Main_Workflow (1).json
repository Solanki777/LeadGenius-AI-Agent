    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1/models/gemini-2.5-flash:generateContent?key=AIzaSyDicG-eFn_RP6s_qMBuXoAsCEUnxcXkmQ0",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\"contents\": [{\"parts\": [{\"text\": \"Extract the following fields from the visiting card text.\\nIf any value is missing, return \\\"None\\\".\\n\\nFields:\\nFull Name\\nCompany Name\\nAddress\\nCity\\nState\\nCountry\\nMobile Number\\nEmail ID\\nBusiness Category\\nIndustry Sector\\nInsight (Short business insight about collaboration potential)\\n\\nReturn ONLY valid JSON.\\n\\nText:\\n\" + $json.raw_text}]}]} }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        672,
        0
      ],
      "id": "51d115d1-b3bd-44a5-8c28-d2edc0ee3a3c",
      "name": "HTTP Request1"
    },
    {
      "parameters": {
        "jsCode": "// --------- VISITING CARD VALIDATION (Business Lead Validation) ----------\n\n// Get parsed AI data\nconst rawText =\n  $json.text ||\n  $json.candidates?.[0]?.content?.parts?.[0]?.text ||\n  \"\";\n\nconst cleanText = rawText\n  .replace(/```json/g, \"\")\n  .replace(/```/g, \"\")\n  .trim();\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(cleanText);\n} catch (e) {\n  parsed = {};\n}\n\n// Extract fields\nconst fullName = parsed[\"Full Name\"] || \"\";\nconst email = parsed[\"Email ID\"] || \"\";\nconst mobile = parsed[\"Mobile Number\"] || \"\";\nconst company = parsed[\"Company Name\"] || \"\";\n\n// --------- VALIDATION RULES (For Business Visiting Card) ----------\nfunction isValidEmail(email) {\n  return /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email);\n}\n\nfunction isValidPhone(phone) {\n  const cleaned = String(phone).replace(/\\D/g, \"\");\n  return cleaned.length >= 8 && cleaned.length <= 15;\n}\n\nfunction isValidName(name) {\n  return name && name.length >= 3 && name !== \"None\";\n}\n\n// Check if visiting card has minimum business info\nconst isBusinessCardValid =\n  isValidName(fullName) &&\n  (isValidEmail(email) || isValidPhone(mobile));\n\n// --------- IF INVALID VISITING CARD → STOP STORAGE ----------\nif (!isBusinessCardValid) {\n  return [\n    {\n      json: {\n        error: true,\n        message: \"Invalid Visiting Card (Missing Name & Contact Info)\",\n        cardType: \"Invalid Business Card\"\n      }\n    }\n  ];\n}\n\n// --------- VALID VISITING CARD → CONTINUE PIPELINE ----------\nreturn [\n  {\n    json: {\n      \"Full Name\": fullName || \"None\",\n      \"Company Name\": company || \"None\",\n      \"Address\": parsed[\"Address\"] || \"None\",\n      \"City\": parsed[\"City\"] || \"None\",\n      \"State\": parsed[\"State\"] || \"None\",\n      \"Country\": parsed[\"Country\"] || \"None\",\n      \"Mobile Number\": mobile || \"None\",\n      \"Email ID\": email || \"None\",\n      \"Business Category\": parsed[\"Business Category\"] || \"None\",\n      \"Industry Sector\": parsed[\"Industry Sector\"] || \"None\",\n      \"Insight\": parsed[\"Insight\"] || \"Valid Business Lead\",\n      \"cardValid\": true,\n      \"Pipeline Stage\": \"Captured\",\n      \"Status\": \"Pending Approval\"\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        16
      ],
